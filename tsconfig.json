{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "composite": true,
    "jsx": "react-jsx"
  },
  "include": ["run.ts", "handlers", "src"]
}
